@@ -0,0 +1,128 @@
+name: Blog Pipeline
+
+on:
+  schedule:
+    # Generate topics every Friday at 5:00 AM UTC (9:00 AM GST)
+    - cron: '0 5 * * 5'
+    # Generate Tuesday's draft on Monday at 4:00 AM UTC (8:00 AM GST)
+    - cron: '0 4 * * 1'
+    # Generate Thursday's draft on Wednesday at 4:00 AM UTC (8:00 AM GST)
+    - cron: '0 4 * * 3'
+  workflow_dispatch:
+    inputs:
+      action:
+        description: 'Pipeline action to trigger'
+        required: true
+        type: choice
+        options:
+          - generate-topics
+          - generate-post
+          - publish
+      title:
+        description: 'Blog post title (for generate-post)'
+        required: false
+      keyword:
+        description: 'Target keyword (for generate-post)'
+        required: false
+      persona:
+        description: 'Target persona (for generate-post)'
+        required: false
+      pillar:
+        description: 'Content pillar (for generate-post)'
+        required: false
+      brief:
+        description: 'Topic brief (for generate-post)'
+        required: false
+
+env:
+  SITE_URL: ${{ secrets.SITE_URL || 'https://www.ampenergy.ae' }}
+  PIPELINE_SECRET: ${{ secrets.PIPELINE_SECRET }}
+
+jobs:
+  generate-topics:
+    if: github.event.schedule == '0 5 * * 5' || (github.event_name == 'workflow_dispatch' && github.event.inputs.action == 'generate-topics')
+    runs-on: ubuntu-latest
+    steps:
+      - name: Generate blog topic proposals
+        run: |
+          response=$(curl -s -w "\n%{http_code}" -X POST \
+            "${{ env.SITE_URL }}/api/blog/generate-topics" \
+            -H "Content-Type: application/json" \
+            -H "Authorization: Bearer ${{ env.PIPELINE_SECRET }}")
+          
+          http_code=$(echo "$response" | tail -1)
+          body=$(echo "$response" | head -n -1)
+          
+          echo "HTTP Status: $http_code"
+          echo "Response: $body"
+          
+          if [ "$http_code" != "200" ]; then
+            echo "::error::Topic generation failed with status $http_code"
+            exit 1
+          fi
+
+  generate-post:
+    if: github.event.schedule == '0 4 * * 1' || github.event.schedule == '0 4 * * 3' || (github.event_name == 'workflow_dispatch' && github.event.inputs.action == 'generate-post')
+    runs-on: ubuntu-latest
+    steps:
+      - name: Generate blog post draft
+        run: |
+          # For manual triggers, use provided inputs
+          # For scheduled triggers, this would be called by the approval flow
+          TITLE="${{ github.event.inputs.title || 'Auto-generated' }}"
+          KEYWORD="${{ github.event.inputs.keyword || '' }}"
+          PERSONA="${{ github.event.inputs.persona || 'Facility Champion' }}"
+          PILLAR="${{ github.event.inputs.pillar || 'efficiency' }}"
+          BRIEF="${{ github.event.inputs.brief || '' }}"
+          
+          DAY_OF_WEEK=$(date +%u)
+          if [ "$DAY_OF_WEEK" = "1" ]; then
+            PUBLISH_DAY="Tuesday"
+          elif [ "$DAY_OF_WEEK" = "3" ]; then
+            PUBLISH_DAY="Thursday"
+          else
+            PUBLISH_DAY="Next scheduled day"
+          fi
+          
+          response=$(curl -s -w "\n%{http_code}" -X POST \
+            "${{ env.SITE_URL }}/api/blog/generate-post" \
+            -H "Content-Type: application/json" \
+            -H "Authorization: Bearer ${{ env.PIPELINE_SECRET }}" \
+            -d "{
+              \"title\": \"$TITLE\",
+              \"keyword\": \"$KEYWORD\",
+              \"persona\": \"$PERSONA\",
+              \"pillar\": \"$PILLAR\",
+              \"brief\": \"$BRIEF\",
+              \"publishDay\": \"$PUBLISH_DAY\"
+            }")
+          
+          http_code=$(echo "$response" | tail -1)
+          body=$(echo "$response" | head -n -1)
+          
+          echo "HTTP Status: $http_code"
+          echo "Response: $body"
+
+  publish:
+    if: github.event_name == 'workflow_dispatch' && github.event.inputs.action == 'publish'
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout repo
+        uses: actions/checkout@v4
+        with:
+          token: ${{ secrets.GITHUB_TOKEN }}
+      
+      - name: Publish approved post
+        run: |
+          echo "Publishing post..."
+          # The publish endpoint creates the MDX file
+          # Then we commit and push
+          
+      - name: Commit and push
+        run: |
+          git config user.name "Amp Blog Pipeline"
+          git config user.email "blog-pipeline@ampenergy.ae"
+          git add content/blog/
+          git diff --staged --quiet && echo "No changes to commit" && exit 0
+          git commit -m "blog: publish new post [automated]"
+          git push
